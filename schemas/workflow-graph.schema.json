{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GnosiST/omyKit/schemas/workflow-graph.schema.json",
  "title": "omyKit Workflow Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "title",
    "mode",
    "created_at",
    "nodes"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "Lite",
        "Standard",
        "Strict"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "title",
          "depends_on",
          "required",
          "retry_limit",
          "acceptance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
          },
          "type": {
            "type": "string",
            "enum": [
              "intake",
              "research",
              "design",
              "plan",
              "implement",
              "verify",
              "review",
              "delivery",
              "evolution"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "required": {
            "type": "boolean"
          },
          "retry_limit": {
            "type": "integer",
            "minimum": 0
          },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "owner": {
            "type": "string",
            "enum": [
              "codex",
              "user",
              "external",
              "tool"
            ]
          },
          "context_level": {
            "type": "string",
            "enum": [
              "scan",
              "focus",
              "deep"
            ]
          }
        }
      }
    }
  }
}
