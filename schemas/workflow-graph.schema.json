{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GnosiST/omyKit/schemas/workflow-graph.schema.json",
  "title": "omyKit Workflow Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "title",
    "mode",
    "created_at",
    "nodes"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "Lite",
        "Standard",
        "Strict"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "title",
          "depends_on",
          "required",
          "retry_limit",
          "acceptance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
          },
          "type": {
            "type": "string",
            "enum": [
              "intake",
              "research",
              "design",
              "plan",
              "implement",
              "verify",
              "review",
              "delivery",
              "evolution"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "title_i18n": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "en": {
                "type": "string",
                "minLength": 1
              },
              "zh-CN": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "objective_i18n": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "en": {
                "type": "string",
                "minLength": 1
              },
              "zh-CN": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "required": {
            "type": "boolean"
          },
          "retry_limit": {
            "type": "integer",
            "minimum": 0
          },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "acceptance_i18n": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "en": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "zh-CN": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "allowed_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "owner": {
            "type": "string",
            "enum": [
              "codex",
              "user",
              "external",
              "tool"
            ]
          },
          "language": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "context_level": {
            "type": "string",
            "enum": [
              "scan",
              "focus",
              "deep"
            ]
          },
          "task_complexity": {
            "type": "string",
            "enum": [
              "simple",
              "standard",
              "complex",
              "expert"
            ]
          },
          "model_tier": {
            "type": "string",
            "enum": [
              "fast",
              "standard",
              "frontier"
            ]
          },
          "model_selection_reason": {
            "type": "string",
            "minLength": 1
          },
          "recommended_model": {
            "type": "string",
            "minLength": 1
          },
          "recommended_model_reason": {
            "type": "string",
            "minLength": 1
          },
          "estimated_minutes": {
            "type": "number",
            "minimum": 0
          },
          "agent": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "model_profile": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "runtime_profile": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "safety_profile": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "scorecard": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "worker_profile": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "claimed_by": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "parallel_group": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "join_policy": {
            "type": "string",
            "enum": [
              "all_required",
              "any_passed",
              "manual_review"
            ]
          },
          "lease_expires_at": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "handoff_target": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          }
        },
        "allOf": [
          {
            "if": {
              "required": [
                "task_complexity"
              ],
              "properties": {
                "task_complexity": {
                  "const": "expert"
                }
              }
            },
            "then": {
              "properties": {
                "model_tier": {
                  "const": "frontier"
                }
              }
            }
          }
        ]
      }
    }
  }
}
