{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GnosiST/omyKit/schemas/workflow-handoff.schema.json",
  "title": "omyKit Workflow Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "node_id",
    "status",
    "summary"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "blocked",
        "skipped"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "inputs_used": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "open_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_blocking_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_recommended_node": {
      "type": "string",
      "minLength": 1
    },
    "reject_to": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "required_fix": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocker_type": {
      "type": "string",
      "enum": [
        "user_confirmation",
        "credential",
        "access",
        "external_state",
        "tool_unavailable",
        "unclear_requirement"
      ]
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "blocked_scope": {
      "type": "string",
      "minLength": 1
    },
    "can_continue_nodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        }
      },
      "then": {
        "required": [
          "outputs",
          "verification"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "required": [
          "reject_to",
          "reason",
          "evidence",
          "required_fix"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "blocked"
          }
        }
      },
      "then": {
        "required": [
          "blocker_type",
          "blocked_scope"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "skipped"
          }
        }
      },
      "then": {
        "required": [
          "reason"
        ]
      }
    }
  ]
}
