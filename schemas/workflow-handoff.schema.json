{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GnosiST/omyKit/schemas/workflow-handoff.schema.json",
  "title": "omyKit Workflow Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "node_id",
    "status",
    "summary"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "blocked",
        "skipped"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "intake_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "route",
        "workflow",
        "assumptions",
        "custom_answers_allowed"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "entry",
            "project_type",
            "mode",
            "next_skill"
          ],
          "properties": {
            "entry": {
              "type": "string",
              "minLength": 1
            },
            "project_type": {
              "type": "string",
              "minLength": 1
            },
            "mode": {
              "type": "string",
              "minLength": 1
            },
            "next_skill": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "workflow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "shape"
          ],
          "properties": {
            "shape": {
              "type": "string",
              "minLength": 1
            },
            "controller_enabled": {
              "type": "boolean"
            },
            "template_id": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "minLength": 1
                  },
                  "impact": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          }
        },
        "questions": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "question",
              "custom_answer_allowed"
            ],
            "properties": {
              "question": {
                "type": "string",
                "minLength": 1
              },
              "answer": {
                "type": "string",
                "minLength": 1
              },
              "options": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "custom_answer_allowed": {
                "type": "boolean"
              },
              "blocking": {
                "type": "boolean"
              },
              "resolved": {
                "type": "boolean"
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "execution_options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "label",
              "summary"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "tradeoffs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "risks": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "recommended": {
                "type": "boolean"
              }
            }
          }
        },
        "selected_option": {
          "type": "string",
          "minLength": 1
        },
        "confirmation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "confirmed",
                "auto_authorized",
                "changed",
                "rejected"
              ]
            },
            "by": {
              "type": "string",
              "minLength": 1
            },
            "evidence": {
              "type": "string",
              "minLength": 1
            },
            "notes": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "custom_answers_allowed": {
          "type": "boolean"
        }
      }
    },
    "evolution_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "lesson",
          "scope",
          "promotion_status",
          "evidence"
        ],
        "properties": {
          "lesson": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "enum": [
              "generic_omykit",
              "project_local",
              "one_off",
              "volatile_ecosystem"
            ]
          },
          "promotion_status": {
            "type": "string",
            "enum": [
              "candidate",
              "promoted",
              "not_promoted",
              "needs_review"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "update_surface": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "capability_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capability",
          "need",
          "current_gap",
          "integration_path",
          "status",
          "evidence"
        ],
        "properties": {
          "capability": {
            "type": "string",
            "minLength": 1
          },
          "need": {
            "type": "string",
            "minLength": 1
          },
          "current_gap": {
            "type": "string",
            "minLength": 1
          },
          "candidate_tool": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "repo": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string",
                "minLength": 1
              },
              "source_mark": {
                "type": "string",
                "minLength": 1
              },
              "license": {
                "type": "string",
                "minLength": 1
              },
              "stars": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "integration_path": {
            "type": "string",
            "enum": [
              "local_only",
              "project_local",
              "omykit_candidate_branch",
              "main_after_review",
              "not_integrated"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "observed",
              "trial_needed",
              "trialing",
              "resolved",
              "not_adopted"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "trial_plan": {
            "type": "string",
            "minLength": 1
          },
          "decision_reason": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "knowledge_sync": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "not_needed",
            "deferred"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "performed_by": {
          "type": "string",
          "minLength": 1
        },
        "files_reviewed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_updated": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "memory_updated": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "deferred"
              }
            }
          },
          "then": {
            "required": [
              "reason"
            ]
          }
        }
      ]
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "model_provider": {
      "type": "string",
      "minLength": 1
    },
    "model_tier": {
      "type": "string",
      "enum": [
        "fast",
        "standard",
        "frontier"
      ]
    },
    "model_selection_reason": {
      "type": "string",
      "minLength": 1
    },
    "skills_used": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "purpose": {
                "type": "string",
                "minLength": 1
              },
              "triggered_by": {
                "type": "string",
                "minLength": 1
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        ]
      }
    },
    "skill_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capability",
          "selected",
          "rationale"
        ],
        "properties": {
          "capability": {
            "type": "string",
            "minLength": 1
          },
          "selected": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "selection_basis": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "decision": {
                  "type": "string",
                  "enum": [
                    "backup",
                    "rejected",
                    "next_retry",
                    "selected"
                  ]
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                },
                "strength": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "fallback_policy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "when": {
                "type": "string",
                "minLength": 1
              },
              "next_skill": {
                "type": "string",
                "minLength": 1
              },
              "action": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "user_feedback": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "accepted",
                  "needs_revision",
                  "rejected",
                  "not_reviewed"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "outcome": {
            "type": "string",
            "enum": [
              "effective",
              "needs_revision",
              "switched",
              "not_evaluated"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "allOf": [
          {
            "if": {
              "required": [
                "outcome"
              ],
              "properties": {
                "outcome": {
                  "enum": [
                    "needs_revision",
                    "switched"
                  ]
                }
              }
            },
            "then": {
              "required": [
                "fallback_policy"
              ],
              "properties": {
                "fallback_policy": {
                  "required": [
                    "next_skill"
                  ]
                }
              }
            }
          }
        ]
      }
    },
    "communication_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auditor_agent_id",
        "decision",
        "reviewed_agents",
        "reviewed_handoffs",
        "evidence_independence",
        "contradiction_status",
        "scope_drift_status"
      ],
      "properties": {
        "auditor_agent_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{1,80}$"
        },
        "decision": {
          "type": "string",
          "enum": [
            "passed",
            "needs_rework",
            "blocked",
            "not_applicable"
          ]
        },
        "reviewed_agents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewed_handoffs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewed_assignments": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_independence": {
          "type": "string",
          "enum": [
            "verified",
            "partial",
            "not_verified",
            "not_applicable"
          ]
        },
        "contradiction_status": {
          "type": "string",
          "enum": [
            "none",
            "resolved",
            "unresolved",
            "not_checked"
          ]
        },
        "scope_drift_status": {
          "type": "string",
          "enum": [
            "none",
            "resolved",
            "unresolved",
            "not_checked"
          ]
        },
        "agreement_without_evidence": {
          "type": "boolean"
        },
        "cross_check_method": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "severity",
              "status",
              "summary"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "open",
                  "resolved",
                  "accepted",
                  "blocking"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "owner": {
                "type": "string",
                "minLength": 1
              },
              "action": {
                "type": "string",
                "minLength": 1
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "nodes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "context_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "context_level": {
          "type": "string",
          "enum": [
            "scan",
            "focus",
            "deep"
          ]
        },
        "source_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "input_files": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "started_at": {
          "type": "string",
          "minLength": 1
        },
        "completed_at": {
          "type": "string",
          "minLength": 1
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_minutes": {
          "type": "number",
          "minimum": 0
        },
        "estimated_completion_at": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputs_used": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "downstream_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_nodes",
        "summary"
      ],
      "properties": {
        "target_nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "required_inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "carry_forward_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "context_budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "scan",
                "focus",
                "deep"
              ]
            },
            "max_source_files": {
              "type": "integer",
              "minimum": 0
            },
            "notes": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "handoff_contract": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "work_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "status"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "reasoning_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cached_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string",
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "usage_observation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_status": {
          "type": "string",
          "enum": [
            "recorded",
            "unavailable",
            "not_applicable",
            "not_recorded"
          ]
        },
        "token_status": {
          "type": "string",
          "enum": [
            "recorded",
            "unavailable",
            "not_applicable",
            "not_recorded"
          ]
