{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GnosiST/omyKit/schemas/workflow-handoff.schema.json",
  "title": "omyKit Workflow Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "node_id",
    "status",
    "summary"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "blocked",
        "skipped"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "intake_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "route",
        "workflow",
        "assumptions",
        "custom_answers_allowed"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "entry",
            "project_type",
            "mode",
            "next_skill"
          ],
          "properties": {
            "entry": {
              "type": "string",
              "minLength": 1
            },
            "project_type": {
              "type": "string",
              "minLength": 1
            },
            "mode": {
              "type": "string",
              "minLength": 1
            },
            "next_skill": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "workflow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "shape"
          ],
          "properties": {
            "shape": {
              "type": "string",
              "minLength": 1
            },
            "controller_enabled": {
              "type": "boolean"
            },
            "template_id": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "minLength": 1
                  },
                  "impact": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          }
        },
        "questions": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "question",
              "custom_answer_allowed"
            ],
            "properties": {
              "question": {
                "type": "string",
                "minLength": 1
              },
              "answer": {
                "type": "string",
                "minLength": 1
              },
              "options": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "custom_answer_allowed": {
                "type": "boolean"
              },
              "blocking": {
                "type": "boolean"
              },
              "resolved": {
                "type": "boolean"
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "custom_answers_allowed": {
          "type": "boolean"
        }
      }
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "model_provider": {
      "type": "string",
      "minLength": 1
    },
    "model_tier": {
      "type": "string",
      "enum": [
        "fast",
        "standard",
        "frontier"
      ]
    },
    "model_selection_reason": {
      "type": "string",
      "minLength": 1
    },
    "skills_used": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "purpose": {
                "type": "string",
                "minLength": 1
              },
              "triggered_by": {
                "type": "string",
                "minLength": 1
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        ]
      }
    },
    "context_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "context_level": {
          "type": "string",
          "enum": [
            "scan",
            "focus",
            "deep"
          ]
        },
        "source_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "input_files": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "started_at": {
          "type": "string",
          "minLength": 1
        },
        "completed_at": {
          "type": "string",
          "minLength": 1
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_minutes": {
          "type": "number",
          "minimum": 0
        },
        "estimated_completion_at": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputs_used": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "work_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "status"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "reasoning_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cached_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string",
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agent_activity": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "agent_id",
          "role",
          "scope",
          "task",
          "status"
        ],
        "properties": {
          "agent_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:-]{1,80}$"
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "task": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "minLength": 1
          },
          "model_tier": {
            "type": "string",
            "enum": [
              "fast",
              "standard",
              "frontier"
            ]
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "model_selection_reason": {
            "type": "string",
            "minLength": 1
          },
          "started_at": {
            "type": "string",
            "minLength": 1
          },
          "completed_at": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "skills_used": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "name"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "source": {
                      "type": "string",
                      "minLength": 1
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "purpose": {
                      "type": "string",
                      "minLength": 1
                    },
                    "triggered_by": {
                      "type": "string",
                      "minLength": 1
                    },
                    "evidence": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                }
              ]
            }
          },
          "token_usage": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source"
            ],
            "properties": {
              "source": {
                "type": "string",
                "minLength": 1
              },
              "provider": {
                "type": "string",
                "minLength": 1
              },
              "model": {
                "type": "string",
                "minLength": 1
              },
              "input_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "output_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "reasoning_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "cached_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "total_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "notes": {
                "type": "string",
                "minLength": 1
              },
              "recorded_at": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "context_usage": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source"
            ],
            "properties": {
              "source": {
                "type": "string",
                "minLength": 1
              },
              "context_level": {
                "type": "string",
                "enum": [
                  "scan",
                  "focus",
                  "deep"
                ]
              },
              "source_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "estimated_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "input_files": {
                "type": "integer",
                "minimum": 0
              },
              "notes": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "open_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_blocking_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_recommended_node": {
      "type": "string",
      "minLength": 1
    },
    "reject_to": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "required_fix": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocker_type": {
      "type": "string",
      "enum": [
        "user_confirmation",
        "credential",
        "access",
        "external_state",
        "tool_unavailable",
        "unclear_requirement"
      ]
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "blocked_scope": {
      "type": "string",
      "minLength": 1
    },
    "can_continue_nodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        }
      },
      "then": {
        "required": [
          "outputs",
          "verification"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "required": [
          "reject_to",
          "reason",
          "evidence",
          "required_fix"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "blocked"
          }
        }
      },
      "then": {
        "required": [
          "blocker_type",
          "blocked_scope"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "skipped"
          }
        }
      },
      "then": {
        "required": [
          "reason"
        ]
      }
    }
  ]
}
