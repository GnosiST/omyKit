{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GnosiST/omyKit/schemas/workflow-node.schema.json",
  "title": "omyKit Workflow Node Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "node_id",
    "type",
    "title",
    "objective",
    "depends_on",
    "context_level",
    "acceptance",
    "allowed_outputs",
    "handoff_required"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
    },
    "type": {
      "type": "string",
      "enum": [
        "intake",
        "research",
        "design",
        "plan",
        "implement",
        "verify",
        "review",
        "delivery",
        "evolution"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "context_level": {
      "type": "string",
      "enum": [
        "scan",
        "focus",
        "deep"
      ]
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "handoff_required": {
      "type": "boolean"
    }
  }
}
