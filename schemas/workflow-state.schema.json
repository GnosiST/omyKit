{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GnosiST/omyKit/schemas/workflow-state.schema.json",
  "title": "omyKit Workflow State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "updated_at",
    "active_node",
    "nodes",
    "retry_edges"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "active_node": {
      "type": [
        "string",
        "null"
      ]
    },
    "active_nodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "nodes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "updated_at"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "ready",
              "running",
              "passed",
              "failed",
              "blocked",
              "skipped"
            ]
          },
          "updated_at": {
            "type": "string",
            "minLength": 1
          },
          "last_handoff": {
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "retry_edges": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
