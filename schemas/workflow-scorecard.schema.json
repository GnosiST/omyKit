{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GnosiST/omyKit/schemas/workflow-scorecard.schema.json",
  "title": "omyKit Workflow Scorecard",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "scorecard_id",
    "name",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "scorecard_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]+$"
    },
    "name": {
      "$ref": "#/definitions/i18nString"
    },
    "description": {
      "$ref": "#/definitions/i18nString"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "title",
          "severity",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]+$"
          },
          "title": {
            "$ref": "#/definitions/i18nString"
          },
          "severity": {
            "type": "string",
            "enum": [
              "required",
              "recommended"
            ]
          },
          "evidence": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "i18nString": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "zh-CN": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
